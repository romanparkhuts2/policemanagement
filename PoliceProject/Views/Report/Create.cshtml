@model PoliceProject.Models.Report
<h1 class="mt-4">Create report</h1>
<h4>Enter data</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label class="control-label">Type:</label>
                <input asp-for="Type" class="form-control" />
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="hidden" asp-for="ReportDate" class="form-control" />
            </div>
            <div class="form-group">
                <label class="control-label">Object type:</label>
                <select asp-for="IdObjectType" class="form-control" asp-items="ViewBag.IdObjectType"></select>
            </div>
            <div class="form-group">
                <label class="control-label">Description</label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Incident date</label>
                <input type="date" asp-for="IncidentDate" class="form-control" />
                <span asp-validation-for="IncidentDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Person</label>
                <select asp-for="IdPerson" class="form-control" asp-items="ViewBag.IdPerson"></select>
                <span asp-validation-for="IdPerson" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Image (286x180)</label>
                <input type="file" asp-for="FileUpload" class="form-control" />
                <span asp-validation-for="FileUpload" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Agent name</label>
                <input asp-for="AgentName" class="form-control" />
                <span asp-validation-for="AgentName" class="text-danger"></span>
            </div>
            @*             <div class="form-group form-check mt-2">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="Solved" /> Solved
                </label>
            </div> *@
            <div class="form-group mt-4">
                <input class="btn btn-success" type="submit" value="Create" />
                <a class="btn btn-primary" asp-action="Index">Go back</a>
            </div>
        </form>
    </div>
    <div class="col-md-8">
        <img src="https://loremflickr.com/800/600/police"
             class="img-fluid rounded shadow"
             alt="Random police image" />
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}