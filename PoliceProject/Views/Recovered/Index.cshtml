@using PoliceProject.Models
@model List<RecoveredItem>

@{
    var percentuale = ViewData["Percentuale"];
}

<div class="mt-4 mb-5 text-center">
    <div class="row align-items-center">
        <div class="col-md-12">
            <h2 class="mb-3">Welcome to the Police Portal</h2>
            <p class="lead" style="display:inline;">
                <strong>Manage reports, findings and people simply and quickly. We have a </strong>
            </p>
            <span style="display:inline; font-size: 24px; font-weight:450;" class="lead text-success"><strong>@percentuale%</strong></span>
            <p style="display:inline;" class="lead"><strong> recovery rate!</strong></p><br />
            <div class="mt-2">
                <a href="/Report/Create" class="btn btn-success me-2 text-white">Create Report</a>
                <a href="/Recovered/Create" class="btn btn-warning text-white">Insert Recovery</a>
            </div>
        </div>
    </div>
</div>

<div class="conteiner">
    <div class="card bg-primary">
        <div style="color:ghostwhite" class="card-header text-center">
            <h1>Recoveries</h1>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-2">
    <div class="d-flex gap-2">
        <a href="/Recovered/Create" class="btn btn-success">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-plus" viewBox="0 0 16 16">
                <path d="M8 6.5a.5.5 0 0 1 .5.5v1.5H10a.5.5 0 0 1 0 1H8.5V11a.5.5 0 0 1-1 0V9.5H6a.5.5 0 0 1 0-1h1.5V7a.5.5 0 0 1 .5-.5" />
                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5z" />
            </svg>  Create recovery
        </a>
    </div>

    <div class="d-flex gap-3">
        <form method="get">
            <div class="d-flex align-items-center gap-2">
                <label for="data" class="mb-0">Filter Date:</label>
                <input type="date" name="data" id="data" />
                <input type="submit" value="Filter" class="btn btn-primary" style="padding-top: 3px; padding-bottom: 3px;" />
            </div>
        </form>
    </div>
</div>

<div class="row">
    @foreach (RecoveredItem recovered in Model)
    {
        <div class="col-4">
            <div class="card shadow mt-3">
                <h5 class="card-header">Recovery</h5>
                <div class="card-body">
                    <div><b>Recovery date</b> @recovered.FoundDate</div>
                    <div style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><b>Description</b> @recovered.Description</div>
                    <div><b>Citizen name</b> @recovered.IdPersonNavigation.Name</div>
                    <div><b>Citizen surname</b> @recovered.IdPersonNavigation.Surname</div>
                    <div class="mt-3">
                        <a href="/Recovered/Delete/@recovered.IdRecoveredItem" class="btn btn-danger">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-trash" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </a>
                        <a href="/Recovered/Modify/@recovered.IdRecoveredItem" class="btn btn-primary ms-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-square" viewBox="0 0 16 16">
                                <path d="M15.502 1.94a.5.5 0 0 1 0 .706L14.459 3.69l-2-2L13.502.646a.5.5 0 0 1 .707 0l1.293 1.293zm-1.75 2.456-2-2L4.939 9.21a.5.5 0 0 0-.121.196l-.805 2.414a.25.25 0 0 0 .316.316l2.414-.805a.5.5 0 0 0 .196-.12l6.813-6.814z" />
                                <path fill-rule="evenodd" d="M1 13.5A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-6a.5.5 0 0 0-1 0v6a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5v-11a.5.5 0 0 1 .5-.5H9a.5.5 0 0 0 0-1H2.5A1.5 1.5 0 0 0 1 2.5z" />
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>